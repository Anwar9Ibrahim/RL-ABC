BM1:    SBEND,  L=0.87808,      ANGLE=+0.785398, FSE={variables['BM1FSE']}

BM2:    DRIFT,  L=0.87808

BM3:    DRIFT,  L=0.87808

WBM4_1: WATCH, filename="results_0/WBM4_1.sdds", mode=coord

BM4:    SBEND,  L=0.87808,      ANGLE=-0.785398, FSE={variables['BM4FSE']}



LL0L1:  DRIFT,  L=0.12

