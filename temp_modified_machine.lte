MBV: MAXAMP,	X_MAX = 0.0123,	Y_MAX = 0.035,	ELLIPTICAL=1

ML:  MAXAMP,	X_MAX = 0.025,	Y_MAX = 0.025,	ELLIPTICAL=1

MS1: MAXAMP,	X_MAX = 0.0125,	Y_MAX = 0.0125,	ELLIPTICAL=1



!Accelerating structure:

RFCavity_d: rfca,freq=2856e6,l=0.03498,volt=0, phase=0, change_p0=1





MA2:    MAXAMP, X_MAX=10.0e-2, Y_MAX=10.0e-2, ELLIPTICAL=1



!PositronLine:









Debuncher: LINE=(43*RFCavity_d)

PInject: LINE=(LM01L0, WQ1L0_1, Q1L0, LL0L1, WQ1L1_1, Q1L1, LL1M1)

PTurn: LINE=(MBH, WBM1_1, BM1, ML, LM1L2, WQ1L2_1_1, Q1L2_1, LL2M2, MBH, BM2, ML, LM2L3, WQ1L3_1_1, Q1L3_1, LL3L4, WQ1L4_1_1, Q1L4_1, LL4L5, WQ1L3_2_1, Q1L3_2, LL5M3, MBH, BM3, ML, LM3L6, WQ1L2_2_1, Q1L2_2, LL6M4, MBH, WBM4_1, BM4, ML)

Debuncher_line: LINE=(LM4L7, WQ1L7_1, Q1L7, LL7L8, WQ1L4_2_1, Q1L4_2, LDB, MA, Debuncher, ML, LDB, WQ1L9_1, Q1L9, LL9L10, WQ1L10_1, Q1L10, LL10M5, MBV)

PositronLine: LINE=(PInject, PTurn, Debuncher_line)

machine: LINE=(q, MA2, PositronLine, final_WP)

